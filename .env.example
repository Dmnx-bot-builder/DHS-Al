# DHS AI Trading Dashboard — Environment Variables
# Copy this file to .env and fill in your credentials.
# If a market data API key is not provided, the app automatically uses mock data.

# ─── Supabase (Backend, Auth, Database) ───
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── API Backend ───
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ─── Market Data Providers ───
# TwelveData API Key — provides real-time XAU/USD OHLCV data
# Get a free key at https://twelvedata.com/
# If left empty, the app runs in MOCK MODE with simulated data.
VITE_TWELVEDATA_API_KEY=

# Polygon.io API Key (future provider)
# VITE_POLYGON_API_KEY=

# Finnhub API Key (future provider)
# VITE_FINNHUB_API_KEY=

# Alpha Vantage API Key (future provider)
# VITE_ALPHAVANTAGE_API_KEY=
